---
/**
 * Centered auth layout — brand logo above the auth card.
 * Wraps page content in the standard auth chrome.
 */
import OrcaBrand from "./OrcaBrand.astro";
import AuthCard from "./AuthCard.astro";
---

<main class="auth-layout">
  <div class="auth-layout__brand">
    <OrcaBrand />
  </div>
  <AuthCard>
    <slot />
  </AuthCard>
</main>

<style>
  .auth-layout {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    min-height: 100vh;
    gap: 32px;
    padding: 24px;
  }

  .auth-layout__brand {
    display: flex;
    justify-content: center;
  }
</style>
