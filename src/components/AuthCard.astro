---
/**
 * White rounded card container for auth forms.
 * Provides the light-on-dark contrast card seen across all auth views.
 */
---

<div class="auth-card">
  <slot />
</div>

<style>
  .auth-card {
    background: #ffffff;
    border-radius: 16px;
    box-shadow: 0 25px 50px rgba(0, 0, 0, 0.4);
    padding: 32px;
    width: 448px;
    max-width: 100%;
  }
</style>
