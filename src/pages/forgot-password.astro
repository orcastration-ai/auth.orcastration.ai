---
import Base from "../layouts/Base.astro";
import AuthLayout from "../components/AuthLayout.astro";
import FormInput from "../components/FormInput.astro";
import FormButton from "../components/FormButton.astro";
---

<Base
  title="Reset password — Orca"
  description="Reset your Orca account password."
>
  <AuthLayout>
    <div class="auth-step">
      <div class="auth-header auth-header--left">
        <a href="/login" class="back-link">
          <svg width="16" height="16" viewBox="0 0 16 16" fill="none" xmlns="http://www.w3.org/2000/svg">
            <path d="M10 12L6 8l4-4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
          Back to sign in
        </a>
        <h1 class="auth-title auth-title--left">Reset your password</h1>
        <p class="auth-subtitle auth-subtitle--left">Enter your email and we'll send you a reset link</p>
      </div>

      <form id="forgot-form" class="auth-form" novalidate>
        <FormInput
          label="Email"
          name="email"
          type="email"
          placeholder="you@example.com"
          required
        />
        <FormButton type="submit">Send reset link</FormButton>
      </form>
    </div>
  </AuthLayout>
</Base>

<style>
  .auth-step {
    display: flex;
    flex-direction: column;
    gap: 24px;
  }

  .auth-header {
    display: flex;
    flex-direction: column;
    gap: 4px;
  }

  .auth-header--left {
    text-align: left;
  }

  .back-link {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    font-family: var(--orca-font-display);
    font-size: 14px;
    color: #314158;
    text-decoration: none;
    margin-bottom: 20px;
  }

  .back-link:hover {
    color: var(--orca-signal);
  }

  .auth-title {
    font-family: var(--orca-font-display);
    font-size: 20px;
    font-weight: 500;
    color: #0f172b;
    line-height: 28px;
    margin: 0;
  }

  .auth-title--left {
    text-align: left;
  }

  .auth-subtitle {
    font-family: var(--orca-font-display);
    font-size: 14px;
    color: #62748e;
    line-height: 20px;
    margin: 0;
  }

  .auth-subtitle--left {
    text-align: left;
  }

  .auth-form {
    display: flex;
    flex-direction: column;
    gap: 16px;
  }
</style>

<script>
  const form = document.getElementById("forgot-form") as HTMLFormElement;

  form.addEventListener("submit", (e) => {
    e.preventDefault();
    const input = form.querySelector<HTMLInputElement>('input[name="email"]')!;
    const error = form.querySelector<HTMLParagraphElement>(".form-input__error")!;

    if (!input.value.trim()) {
      error.textContent = "Email is required";
      return;
    }

    error.textContent = "";
    // Password reset flow will be wired up when backend is ready
  });
</script>
