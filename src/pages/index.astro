---
import Base from "../layouts/Base.astro";
---

<Base
  title="Authentication — Orca"
  description="Secure, seamless authentication for the Orca platform."
>
  <main class="coming-soon">
    <div class="orca-container">
      <img src="/favicon.svg" alt="Orca" class="logo" width="48" height="48" />
      <span class="orca-section-label">Coming Soon</span>
      <h1 class="orca-section-title">
        <span class="orca-gradient-text">Authentication</span>
      </h1>
      <p class="orca-section-lead">
        Secure, seamless authentication for the Orca platform.
      </p>
      <a href="https://orcastration.ai" class="back-link orca-link-underline">
        orcastration.ai
      </a>
    </div>
  </main>
</Base>

<style>
  .coming-soon {
    display: flex;
    align-items: center;
    justify-content: center;
    min-height: 100vh;
    text-align: center;
  }

  .logo {
    margin-bottom: 2rem;
  }

  .orca-section-label {
    margin-bottom: 1rem;
  }

  .orca-section-title {
    margin-bottom: 1.5rem;
  }

  .orca-section-lead {
    margin-bottom: 2.5rem;
  }

  .back-link {
    color: var(--orca-mist);
    font-family: var(--orca-font-mono);
    font-size: 0.85rem;
  }
</style>
