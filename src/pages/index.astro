---
/**
 * Root redirect — sends visitors to the login page.
 * Uses meta refresh since this is a static build (no SSR).
 */
---

<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta http-equiv="refresh" content="0;url=/login" />
    <link rel="canonical" href="/login" />
    <title>Redirecting…</title>
  </head>
  <body>
    <p>Redirecting to <a href="/login">sign in</a>…</p>
  </body>
</html>
