---
import Base from "../layouts/Base.astro";
import AuthLayout from "../components/AuthLayout.astro";
import FormInput from "../components/FormInput.astro";
import FormButton from "../components/FormButton.astro";
import Divider from "../components/Divider.astro";
import SocialButtons from "../components/SocialButtons.astro";
import WalletButton from "../components/WalletButton.astro";
---

<Base
  title="Create account — Orca"
  description="Create your Orca account."
>
  <AuthLayout>
    <div class="auth-step">
      <div class="auth-header">
        <h1 class="auth-title">Create your account</h1>
        <p class="auth-subtitle">Get started with Orca</p>
      </div>

      <form id="register-form" class="auth-form" novalidate>
        <FormInput
          label="Email"
          name="email"
          type="email"
          placeholder="you@example.com"
          required
        />
        <FormButton type="submit">Continue</FormButton>
      </form>

      <Divider />

      <SocialButtons />

      <WalletButton label="Create account with wallet" />

      <div class="auth-footer">
        <p class="auth-footer__text">
          Already have an account? <a href="/login" class="auth-link">Sign in</a>
        </p>
      </div>
    </div>
  </AuthLayout>
</Base>

<style>
  .auth-step {
    display: flex;
    flex-direction: column;
    gap: 24px;
  }

  .auth-header {
    text-align: center;
    display: flex;
    flex-direction: column;
    gap: 4px;
  }

  .auth-title {
    font-family: var(--orca-font-display);
    font-size: 20px;
    font-weight: 500;
    color: #0f172b;
    line-height: 28px;
    margin: 0;
  }

  .auth-subtitle {
    font-family: var(--orca-font-display);
    font-size: 14px;
    color: #62748e;
    line-height: 20px;
    margin: 0;
  }

  .auth-form {
    display: flex;
    flex-direction: column;
    gap: 16px;
  }

  .auth-footer {
    border-top: 1px solid #f1f5f9;
    padding-top: 17px;
  }

  .auth-footer__text {
    font-family: var(--orca-font-display);
    font-size: 14px;
    color: #45556c;
    text-align: center;
    margin: 0;
  }

  .auth-link {
    color: var(--orca-signal);
    text-decoration: none;
  }

  .auth-link:hover {
    text-decoration: underline;
  }
</style>

<script>
  const form = document.getElementById("register-form") as HTMLFormElement;

  form.addEventListener("submit", (e) => {
    e.preventDefault();
    const input = form.querySelector<HTMLInputElement>('input[name="email"]')!;
    const error = form.querySelector<HTMLParagraphElement>(".form-input__error")!;

    if (!input.value.trim()) {
      error.textContent = "Email is required";
      return;
    }

    error.textContent = "";
    // Registration flow will be wired up when backend is ready
  });
</script>
